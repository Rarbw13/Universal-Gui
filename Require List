    for _, v in pairs(game:GetDescendants()) do
        pcall(function()
            if v:IsA("LuaSourceContainer") then
                if string.find(v.Source, "require") or string.find(v.Source, "loadstring") or string.find(v.Source, "backdoor") then
                    found = true
                end
            end
        end)
    end
    
    if found then
        Notify("Backdoor Detected, Loaded HD Admin...")
        task.wait(0.5)
        require(7192763922).load(lp)
