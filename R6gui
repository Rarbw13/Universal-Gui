-- Scrolling Container (Kunci agar tidak nembus)
local scrollFrame = Instance.new("ScrollingFrame", main)
scrollFrame.Size = UDim2.new(0, 470, 0, 280) -- Ukuran tetap di dalam main frame
scrollFrame.Position = UDim2.new(0, 155, 0, 55)
scrollFrame.BackgroundTransparency = 1
scrollFrame.ClipsDescendants = true -- Menahan tombol agar tetap di dalam kotak
scrollFrame.ScrollBarThickness = 5
scrollFrame.ScrollBarImageColor3 = Color3.fromRGB(255, 0, 0)
scrollFrame.CanvasSize = UDim2.new(0, 0, 0, 0) -- Otomatis memanjang sesuai jumlah tombol

local layout = Instance.new("UIGridLayout", scrollFrame)
layout.CellSize = UDim2.new(0, 140, 0, 45)
layout.CellPadding = UDim2.new(0, 10, 0, 10)
layout.SortOrder = Enum.SortOrder.LayoutOrder

-- Auto Resize Canvas agar scroll aktif jika tombol banyak
layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
	scrollFrame.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 20)
end)

-- List Scripts
local lScripts = {
	["Fly v3"] = "https://raw.githubusercontent.com/XNEOFF/FlyGuiV3/main/FlyGuiV3.txt",
	["Touch Fling"] = "https://pastebin.com/raw/LgZwZ7ZB",
	["Yarhm"] = "https://raw.githubusercontent.com/Joystickplays/psychic-octo-invention/main/yarhm.lua",
	["Invisible"] = "https://pastebin.com/raw/3Rnd9rHf",
	["Vortex"] = "https://raw.githubusercontent.com/GoofyBlox/GoofyZ/refs/heads/main/Best/Vortex.lua",
	["Solara Hub"] = "https://raw.githubusercontent.com/samuraa1/Solara-Hub/refs/heads/main/Solara%20Hub.lua",
	["Noclip"] = "noclip",
	["Reclip"] = "reclip",
	["Skybox"] = "Skybox",
	["Kater Hub"] = "https://raw.githubusercontent.com/KaterHub-Inc/NaturalDisasterSurvival/refs/heads/main/main.lua",
	["Absense"] = "https://raw.githubusercontent.com/vnausea/absence-mini/refs/heads/main/absencemini.lua",
	["Bloxburg"] = "https://luxhub.cc/script.lua",
	["Inf Health"] = "https://pastebin.com/SEsnu32m",
	["Annabypasser"] = "https://raw.githubusercontent.com/AnnaRoblox/AnnaBypasser/refs/heads/main/AnnaBypasser.lua",
	["God Mode"] = "https://pastebin.com/raw/eD8HBXGS",
	["Universal Wallhop"] = "https://rawscripts.net/raw/Universal-Script-Universal-Wallhop-Script-123263",
	["FE k00pkidd"] = "https://raw.githubusercontent.com/Rarbw13/Universal-Gui/refs/heads/main/k00pkiddGUI",
	["Tubers Sound"] = "https://raw.githubusercontent.com/Rarbw13/Universal-Gui/refs/heads/main/Tubers%20Sound",
	["Ring Parts"] = "loadstring(game:HttpGet('https://raw.githubusercontent.com/Lukashub-coder/super-ring/refs/heads/main/Super%20ring!!'))()",
	["SystemBroken"] = "https://raw.githubusercontent.com/H20CalibreYT/SystemBroken/main/script",
}

_G.nc = false

for name, link in pairs(lScripts) do
	local b = Instance.new("TextButton", scrollFrame)
	b.Text = name
	b.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
	b.TextColor3 = Color3.new(1, 1, 1)
	b.Font = Enum.Font.GothamBold
	b.TextSize = 12
	Instance.new("UICorner", b).CornerRadius = UDim.new(0, 6)
	
	local stroke = Instance.new("UIStroke", b)
	stroke.Color = Color3.fromRGB(50, 50, 50)
	stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border

	b.MouseButton1Click:Connect(function()
		if link == "noclip" then
			_G.nc = true
			RunService.Stepped:Connect(function()
				if _G.nc and LocalPlayer.Character then
					for _, v in pairs(LocalPlayer.Character:GetDescendants()) do
						if v:IsA("BasePart") then v.CanCollide = false end
					end
				end
			end)
		elseif link == "reclip" then
			_G.nc = false
			if LocalPlayer.Character then
				for _, v in pairs(LocalPlayer.Character:GetDescendants()) do
					if v:IsA("BasePart") then v.CanCollide = true end
				end
			end
		elseif link == "Skybox" then
			task.spawn(function()
				for _, v in pairs(Lighting:GetChildren()) do
					if v:IsA("Sky") or v:IsA("Atmosphere") then v:Destroy() end
				end
				local s = Instance.new("Sky", Lighting)
				local id = "rbxassetid://9422866248"
				s.SkyboxBk = id s.SkyboxDn = id s.SkyboxFt = id
				s.SkyboxLf = id s.SkyboxRt = id s.SkyboxUp = id
				Lighting.ClockTime = 12
			end)
		elseif string.find(link, "loadstring") then
			pcall(function() loadstring(link)() end)
		else
			pcall(function() loadstring(game:HttpGet(link))() end)
		end
	end)
end

