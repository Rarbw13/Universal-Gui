-- R6gui Final Optimized (Clean Code, Proper Scrolling, Big Close Button)
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")
local Lighting = game:GetService("Lighting")
local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")

-- Destroy existing GUI
if PlayerGui:FindFirstChild("R6gui") then
	PlayerGui.R6gui:Destroy()
end

local gui = Instance.new("ScreenGui", PlayerGui)
gui.Name = "R6gui"
gui.IgnoreGuiInset = true
gui.ResetOnSpawn = false

-- Splash Screen
local splash = Instance.new("Frame", gui)
splash.BackgroundColor3 = Color3.new(0, 0, 0)
splash.Size = UDim2.new(1, 0, 1, 0)
splash.ZIndex = 10

local splashLogo = Instance.new("TextLabel", splash)
splashLogo.Size = UDim2.new(0, 160, 0, 60)
splashLogo.Position = UDim2.new(0.5, -80, 0.5, -30)
splashLogo.BackgroundTransparency = 1
splashLogo.Text = "R6gui"
splashLogo.Font = Enum.Font.GothamBold
splashLogo.TextSize = 42
splashLogo.TextColor3 = Color3.new(1, 1, 1)

task.wait(1)
TweenService:Create(splash, TweenInfo.new(0.8), {BackgroundTransparency = 1}):Play()
TweenService:Create(splashLogo, TweenInfo.new(0.8), {TextTransparency = 1}):Play()
task.delay(0.8, function() splash:Destroy() end)

